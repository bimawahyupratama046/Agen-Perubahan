    // ===== STATISTICS =====
    function updateStats() {
      const visits = allData.filter(d => d.type === 'visit');
      const today = new Date().toISOString().split('T')[0];
      const thisMonth = today.substring(0, 7);

      document.getElementById('stat-total').textContent = visits.length;
      document.getElementById('stat-month').textContent = visits.filter(v => v.visitor_date && v.visitor_date.startsWith(thisMonth)).length;
      document.getElementById('stat-today').textContent = visits.filter(v => v.visitor_date === today).length;
    }

    function setChartType(type) {
      chartType = type;
      document.getElementById('btn-bar').className = `px-4 py-2 rounded-lg text-sm font-medium ${type === 'bar' ? 'bg-blue-600 text-white' : 'bg-blue-100 text-blue-700'}`;
      document.getElementById('btn-line').className = `px-4 py-2 rounded-lg text-sm font-medium ${type === 'line' ? 'bg-blue-600 text-white' : 'bg-blue-100 text-blue-700'}`;
      renderChart();
    }

    function setChartPeriod(period) {
      chartPeriod = period;
      ['year','month','day'].forEach(p => {
        document.getElementById('btn-' + p).className = `px-3 py-1.5 rounded-lg text-xs font-medium ${p === period ? 'bg-blue-200 text-blue-800' : 'bg-blue-100 text-blue-700'}`;
      });
      renderChart();
    }

    function renderChart() {
      const svg = document.getElementById('chart-svg');
      const visits = allData.filter(d => d.type === 'visit');
      let labels = [], values = [];

      if (chartPeriod === 'year') {
        const years = {};
        visits.forEach(v => { if (v.visitor_date) { const y = v.visitor_date.substring(0, 4); years[y] = (years[y] || 0) + 1; } });
        const sortedYears = Object.keys(years).sort();
        if (sortedYears.length === 0) { const cy = new Date().getFullYear(); for (let i = cy - 2; i <= cy; i++) { labels.push(String(i)); values.push(years[i] || 0); } }
        else { sortedYears.forEach(y => { labels.push(y); values.push(years[y]); }); }
      } else if (chartPeriod === 'month') {
        const months = ['Jan','Feb','Mar','Apr','Mei','Jun','Jul','Ags','Sep','Okt','Nov','Des'];
        const cy = new Date().getFullYear();
        for (let i = 0; i < 12; i++) {
          labels.push(months[i]);
          const key = `${cy}-${String(i + 1).padStart(2, '0')}`;
          values.push(visits.filter(v => v.visitor_date && v.visitor_date.startsWith(key)).length);
        }
      } else {
        const days = ['Sen','Sel','Rab','Kam','Jum','Sab','Min'];
        const today = new Date();
        for (let i = 6; i >= 0; i--) {
          const d = new Date(today); d.setDate(d.getDate() - i);
          const key = d.toISOString().split('T')[0];
          labels.push(days[d.getDay() === 0 ? 6 : d.getDay() - 1]);
          values.push(visits.filter(v => v.visitor_date === key).length);
        }
      }

      const w = svg.clientWidth || 700;
      const h = 260;
      const padding = { top: 20, right: 20, bottom: 40, left: 40 };
      const chartW = w - padding.left - padding.right;
      const chartH = h - padding.top - padding.bottom;
      const maxVal = Math.max(...values, 1);

      let html = '';
      // Grid
      for (let i = 0; i <= 4; i++) {
        const y = padding.top + (chartH / 4) * i;
        html += `<line x1="${padding.left}" y1="${y}" x2="${w - padding.right}" y2="${y}" stroke="#dbeafe" stroke-width="1"/>`;
        html += `<text x="${padding.left - 8}" y="${y + 4}" text-anchor="end" fill="#6b7280" font-size="10">${Math.round(maxVal - (maxVal / 4) * i)}</text>`;
      }

      const barW = chartW / labels.length;

      if (chartType === 'bar') {
        labels.forEach((label, i) => {
          const x = padding.left + barW * i + barW * 0.2;
          const barHeight = (values[i] / maxVal) * chartH;
          const y = padding.top + chartH - barHeight;
          html += `<rect x="${x}" y="${y}" width="${barW * 0.6}" height="${barHeight}" fill="#3b82f6" rx="4" class="stat-bar"/>`;
          html += `<text x="${padding.left + barW * i + barW / 2}" y="${h - 10}" text-anchor="middle" fill="#6b7280" font-size="10">${label}</text>`;
          if (values[i] > 0) html += `<text x="${padding.left + barW * i + barW / 2}" y="${y - 5}" text-anchor="middle" fill="#2563eb" font-size="10" font-weight="bold">${values[i]}</text>`;
        });
      } else {
        let points = [];
        labels.forEach((label, i) => {
          const x = padding.left + barW * i + barW / 2;
          const y = padding.top + chartH - (values[i] / maxVal) * chartH;
          points.push(`${x},${y}`);
          html += `<text x="${x}" y="${h - 10}" text-anchor="middle" fill="#6b7280" font-size="10">${label}</text>`;
        });
        // Area
        html += `<polygon points="${padding.left + barW / 2},${padding.top + chartH} ${points.join(' ')} ${padding.left + barW * (labels.length - 1) + barW / 2},${padding.top + chartH}" fill="rgba(59,130,246,0.1)"/>`;
        html += `<polyline points="${points.join(' ')}" fill="none" stroke="#3b82f6" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>`;
        points.forEach((p, i) => {
          const [x, y] = p.split(',');
          html += `<circle cx="${x}" cy="${y}" r="4" fill="#2563eb" class="line-point"/>`;
          if (values[i] > 0) html += `<text x="${x}" y="${y - 10}" text-anchor="middle" fill="#2563eb" font-size="10" font-weight="bold">${values[i]}</text>`;
        });
      }

      svg.innerHTML = html;
    }

    // ===== NILAI PAGE =====
    function updateNilaiPage() {
      const scores = allData.filter(d => d.type === 'score').sort((a, b) => (b.visitor_date || '').localeCompare(a.visitor_date || ''));
      const container = document.getElementById('nilai-list');
      const empty = document.getElementById('nilai-empty');

      if (scores.length === 0) {
        container.innerHTML = '';
        empty.classList.remove('hidden');
        return;
      }
      empty.classList.add('hidden');
      container.innerHTML = scores.map(s => {
        const pct = s.quiz_score || 0;
        const color = pct >= 80 ? 'green' : pct >= 60 ? 'yellow' : 'red';
        const date = s.visitor_date ? new Date(s.visitor_date).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' }) : '-';
        return `
          <div class="flex items-center gap-4 bg-white border border-blue-100 rounded-xl p-4 shadow-sm">
            <div class="w-12 h-12 rounded-full bg-${color}-100 flex items-center justify-center">
              <span class="text-${color}-600 font-bold text-sm">${pct}%</span>
            </div>
            <div class="flex-1">
              <p class="font-semibold text-blue-800 text-sm">${s.quiz_topic || 'Quiz'}</p>
              <p class="text-xs text-blue-400">${date}</p>
            </div>
            <div class="text-right">
              <p class="text-xs text-blue-500">${Math.round(pct * 20 / 100)} / 20 benar</p>
            </div>
          </div>
        `;
      }).join('');
    }
